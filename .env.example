# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/starpass"
DOCKER_DATABASE_URL="postgresql://postgres:password@postgres:5432/starpass"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="starpass"
TEST_POSTGRES_USER="postgres"
TEST_POSTGRES_PASSWORD="password"
TEST_POSTGRES_DB="starpass_test"

# Redis
REDIS_URL="redis://localhost:6379"
DOCKER_REDIS_URL="redis://redis:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Stellar
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_NETWORK="testnet"
STARPASS_CONTRACT_ID="YOUR_DEPLOYED_CONTRACT_ID"
STELLAR_FRIENDBOT_URL="https://friendbot.stellar.org"

# Indexer
INDEXER_ENABLED="true"
INDEXER_INTERVAL_MS="10000"

# App
PORT=4000
FRONTEND_URL="http://localhost:3000"

# SMTP Configuration
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user"
SMTP_PASS="password"
FROM_EMAIL="noreply@starpass.com"
