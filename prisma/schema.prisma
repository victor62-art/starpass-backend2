generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  stellarAddress String    @unique @map("stellar_address")
  role           UserRole  @default(FAN)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  creator        Creator?
  fan            Fan?
  sessions       Session[]
  @@map("users")
}

enum UserRole {
  CREATOR
  FAN
  ADMIN
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model Creator {
  id             String    @id @default(uuid())
  userId         String    @unique @map("user_id")
  stellarAddress String    @unique @map("stellar_address")
  email          String?   @unique
  displayName    String    @map("display_name")
  bio            String?
  avatarUrl      String?   @map("avatar_url")
  totalEarned    Decimal   @default(0) @map("total_earned")
  registeredAt   DateTime  @map("registered_at")
  featured       Boolean   @default(false)
  featuredOrder  Int       @default(0) @map("featured_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tiers          Tier[]
  passes         Pass[]
  blocks         Block[]
  webhooks       WebhookConfig[]
  payouts        Payout[]
  earningsRecords EarningsRecord[]
  @@map("creators")
}

enum PayoutStatus {
  PENDING
  COMPLETED
  FAILED
}

model Payout {
  id        String       @id @default(uuid())
  creatorId String       @map("creator_id")
  amount    Decimal
  txHash    String?      @map("tx_hash")
  status    PayoutStatus @default(PENDING)
  createdAt DateTime     @default(now()) @map("created_at")
  creator   Creator      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  @@map("payouts")
}

model WebhookConfig {
  id        String   @id @default(uuid())
  creatorId String   @map("creator_id")
  url       String
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  @@map("webhook_configs")
}

model Fan {
  id                  String    @id @default(uuid())
  userId              String    @unique @map("user_id")
  stellarAddress      String    @unique @map("stellar_address")
  displayName         String?   @map("display_name")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletionRequestedAt DateTime? @map("deletion_requested_at")
  anonymized          Boolean   @default(false)
  permanentlyDeletedAt DateTime? @map("permanently_deleted_at")
  lastExportRequestedAt DateTime? @map("last_export_requested_at")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  passes              Pass[]
  earningsRecords     EarningsRecord[]
  @@map("fans")
}

model Tier {
  id           String        @id @default(uuid())
  onChainId    Int           @map("on_chain_id")
  creatorId    String        @map("creator_id")
  name         String
  description  String?
  priceUsdc    Decimal       @map("price_usdc")
  durationDays Int           @map("duration_days")
  maxSupply    Int           @default(0) @map("max_supply")
  minted       Int           @default(0)
  active       Boolean       @default(true)
  syncedAt     DateTime      @map("synced_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  creator      Creator       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  passes       Pass[]
  waitlist     WaitlistEntry[]
  earningsRecords EarningsRecord[]
  prices       TierPrice[]
  @@unique([creatorId, onChainId])
  @@map("tiers")
}

model TierPrice {
  id        String   @id @default(uuid())
  tierId    String   @map("tier_id")
  token     String
  amount    Decimal
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tier      Tier     @relation(fields: [tierId], references: [id], onDelete: Cascade)
  @@unique([tierId, token])
  @@map("tier_prices")
}

model WaitlistEntry {
  id           String   @id @default(uuid())
  tierId       String   @map("tier_id")
  fanAddress   String   @map("fan_address")
  joinedAt      DateTime @default(now()) @map("joined_at")
  notified     Boolean  @default(false)
  tier          Tier     @relation(fields: [tierId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  @@unique([tierId, fanAddress])
  @@map("waitlist_entries")
}

model Pass {
  id          String   @id @default(uuid())
  onChainId   BigInt   @unique @map("on_chain_id")
  tierId      String   @map("tier_id")
  creatorId   String   @map("creator_id")
  fanId       String   @map("fan_id")
  purchasedAt DateTime @map("purchased_at")
  expiresAt   DateTime @map("expires_at")
  txHash      String?  @map("tx_hash")
  active      Boolean  @default(true)
  syncedAt    DateTime @map("synced_at")
  createdAt   DateTime @default(now()) @map("created_at")
  tier        Tier     @relation(fields: [tierId], references: [id])
  creator     Creator  @relation(fields: [creatorId], references: [id])
  fan         Fan      @relation(fields: [fanId], references: [id])
  @@map("passes")
}

model EarningsRecord {
  id        String   @id @default(uuid())
  creatorId String   @map("creator_id")
  fanId     String   @map("fan_id")
  tierId    String   @map("tier_id")
  amount    Decimal  @map("amount")
  fee       Decimal  @default(0) @map("fee")
  netAmount Decimal  @map("net_amount")
  createdAt DateTime @default(now()) @map("created_at")
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  fan       Fan      @relation(fields: [fanId], references: [id], onDelete: Cascade)
  tier      Tier     @relation(fields: [tierId], references: [id])
  @@map("earnings_records")
}

model IndexerCheckpoint {
  id         String   @id @default("singleton")
  lastLedger Int      @default(0) @map("last_ledger")
  updatedAt  DateTime @updatedAt @map("updated_at")
  @@map("indexer_checkpoints")
}

model PlatformConfig {
  id          String   @id @default("singleton")
  feeBps      Int      @default(250) @map("fee_bps")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")
  @@map("platform_configs")
}

model Block {
  id        String   @id @default(uuid())
  creatorId String   @map("creator_id")
  blockedAddress String @map("blocked_address")
  createdAt DateTime @default(now()) @map("created_at")
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  @@unique([creatorId, blockedAddress])
  @@map("blocks")
}